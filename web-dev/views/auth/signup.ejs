<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Signup</title>
  <link rel="stylesheet" href="/output.css" />
</head>

<body class="min-h-screen flex flex-col bg-gradient-to-br from-blue-100 via-white to-blue-200 text-gray-800">

<%- include('../partials/navbar') %>

<div class="flex flex-1 items-center justify-center px-4">
  <div class="w-full max-w-md bg-white rounded-2xl shadow-xl p-6 border border-blue-100">

    <h2 class="text-2xl font-bold text-center text-blue-600 mb-6">
      Signup
    </h2>

    <form action="/signup" method="POST">

     <%- include('../partials/error') %>

      <!-- First Name -->
      <div class="mb-3">
        <label class="block text-sm font-medium text-blue-700 mb-1">
          First Name
        </label>
        <input
          type="text"
          name="firstName"
          placeholder="First name"
          value="<%= oldInput.firstName || '' %>"
          class="w-full px-3 py-2 border border-blue-300 rounded-lg focus:ring-2 focus:ring-blue-500"
        />
      </div>

      <!-- Last Name -->
      <div class="mb-3">
        <label class="block text-sm font-medium text-blue-700 mb-1">
          Last Name
        </label>
        <input
          type="text"
          name="lastName"
          placeholder="Last name"
          value="<%= oldInput.lastName || '' %>"
          class="w-full px-3 py-2 border border-blue-300 rounded-lg focus:ring-2 focus:ring-blue-500"
        />
      </div>

      <!-- Email -->
      <div class="mb-3">
        <label class="block text-sm font-medium text-blue-700 mb-1">
          Email
        </label>
        <input
          type="email"
          name="email"
          placeholder="user@mail.com"
          value="<%= oldInput.email || '' %>"
          class="w-full px-3 py-2 border border-blue-300 rounded-lg focus:ring-2 focus:ring-blue-500"
        />
      </div>

      <!-- Password -->
      <div class="mb-3">
        <label class="block text-sm font-medium text-blue-700 mb-1">
          Password
        </label>
        <input
          type="password"
          name="password"
          class="w-full px-3 py-2 border border-blue-300 rounded-lg focus:ring-2 focus:ring-blue-500"
        />
      </div>

      <!-- Confirm Password -->
      <div class="mb-3">
        <label class="block text-sm font-medium text-blue-700 mb-1">
          Confirm Password
        </label>
        <input
          type="password"
          name="confirm_password"
          class="w-full px-3 py-2 border border-blue-300 rounded-lg focus:ring-2 focus:ring-blue-500"
        />
      </div>

      <!-- User Type -->
      <div class="mb-4">
        <label class="block text-sm font-medium text-blue-700 mb-2">
          User Type
        </label>
        <div class="flex gap-6 text-sm">
          <label class="flex items-center gap-2">
            <input
              type="radio"
              name="userType"
              value="guest"
              <%= oldInput.userType === 'guest' ? 'checked' : '' %>
            />
            Guest
          </label>

          <label class="flex items-center gap-2">
            <input
              type="radio"
              name="userType"
              value="host"
              <%= oldInput.userType === 'host' ? 'checked' : '' %>
            />
            Host
          </label>
        </div>
      </div>

      <!-- Terms -->
      <div class="mb-4">
        <label class="flex items-center gap-2 text-sm text-gray-600">
          <input type="checkbox" name="termsAccepted" />
          I agree to the Terms and Conditions
        </label>
      </div>

      <button
        type="submit"
        class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 rounded-lg transition"
      >
        Signup
      </button>

    </form>

    <p class="text-center text-xs text-gray-500 mt-6">
      Already have an account?
      <a href="/login" class="text-blue-600 hover:underline font-medium">
        Login
      </a>
    </p>

  </div>
</div>

<%- include('../partials/footer') %>

</body>
</html>
