<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
  nav { font-family: 'Plus Jakarta Sans', sans-serif; }

  .nav-brand { font-size: 20px; font-weight: 700; color: #2563EB; text-decoration: none; letter-spacing: -0.4px; margin-left: 8px; }

  .nav-link { font-size: 14px; font-weight: 500; color: #6b7280; text-decoration: none; padding: 8px 16px; border-radius: 10px; transition: color 0.15s, background 0.15s; white-space: nowrap; }
  .nav-link:hover { color: #111827; background: #f9fafb; }
  .nav-link.active { color: #2563EB; background: #eff6ff; font-weight: 600; }

  .user-pill { display: flex; align-items: center; gap: 10px; background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 50px; padding: 6px 16px 6px 6px; transition: box-shadow 0.15s, border-color 0.15s; }
  .user-pill:hover { box-shadow: 0 2px 10px rgba(37,99,235,0.1); border-color: #bfdbfe; }

  .nav-avatar { width: 32px; height: 32px; border-radius: 50%; background: #2563EB; color: #fff; font-size: 12px; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }

  .btn-logout { font-size: 13px; font-weight: 600; color: #6b7280; background: none; border: 1px solid #e5e7eb; border-radius: 10px; padding: 8px 16px; cursor: pointer; transition: all 0.15s; font-family: 'Plus Jakarta Sans', sans-serif; }
  .btn-logout:hover { color: #dc2626; border-color: #fca5a5; background: #fef2f2; }

  .btn-signup { font-size: 14px; font-weight: 600; color: #fff; background: #2563EB; border-radius: 10px; padding: 9px 20px; text-decoration: none; transition: background 0.15s; box-shadow: 0 2px 8px rgba(37,99,235,0.25); }
  .btn-signup:hover { background: #1d4ed8; }

  .hbg { background: none; border: 1px solid #e5e7eb; cursor: pointer; padding: 9px 10px; border-radius: 10px; display: flex; flex-direction: column; gap: 5px; align-items: center; transition: background 0.15s; }
  .hbg:hover { background: #f9fafb; }
  .hbg span { display: block; width: 18px; height: 2px; background: #374151; border-radius: 2px; }

  .mob-drawer { overflow: hidden; max-height: 0; transition: max-height 0.3s ease; background: #fff; border-top: 1px solid #e5e7eb; }
  .mob-drawer.open { max-height: 360px; }
  .mob-link { font-size: 14px; font-weight: 500; color: #6b7280; text-decoration: none; padding: 11px 14px; border-radius: 10px; display: flex; align-items: center; gap: 10px; transition: all 0.15s; }
  .mob-link:hover { color: #111827; background: #f9fafb; }
  .mob-link.active { color: #2563EB; background: #eff6ff; font-weight: 600; }
</style>

<nav style="background:#fff; border-bottom:1px solid #e5e7eb; box-shadow:0 2px 12px rgba(0,0,0,0.06); position:sticky; top:0; z-index:50;">

  <%# ── DESKTOP ── %>
  <div class="hidden sm:flex max-w-7xl mx-auto items-center justify-between px-10 h-16 gap-4">

    <a href="/" class="nav-brand">Airbnb</a>

    <div class="flex items-center gap-1">
      <% if (isLoggedIn) { %>
        <% if (user && user.userType === 'guest') { %>
          <a href="/bookings" class="nav-link <%= path === '/bookings' ? 'active' : '' %>">Bookings</a>
          <a href="/favourites" class="nav-link <%= path === '/favourites' ? 'active' : '' %>">Favourites</a>
        <% } else { %>
          <a href="/host/add-home" class="nav-link <%= path === '/host/add-home' ? 'active' : '' %>">Add Home</a>
          <a href="/host/list-home" class="nav-link <%= path === '/host/list-home' ? 'active' : '' %>">My Homes</a>
          <a href="/host/orders" class="nav-link <%= path === '/host/orders' || path === '/host/order' ? 'active' : '' %>">Orders</a>
        <% } %>
      <% } %>
    </div>

    <div class="flex items-center gap-2.5">
      <% if (!isLoggedIn) { %>
        <a href="/login" class="nav-link">Login</a>
        <a href="/signup" class="btn-signup">Sign Up</a>
      <% } else if (user) { %>
        <div class="user-pill">
          <div class="nav-avatar"><%= user.firstName.charAt(0).toUpperCase() %></div>
          <div style="display:flex; flex-direction:column; line-height:1.25;">
            <span style="font-size:10px; font-weight:700; color:#2563EB; text-transform:uppercase; letter-spacing:0.5px;"><%= user.userType %></span>
            <span style="font-size:13px; font-weight:600; color:#111827;"><%= user.firstName %></span>
          </div>
        </div>
        <form action="/logout" method="POST" class="inline m-0">
          <button type="submit" class="btn-logout">Logout</button>
        </form>
      <% } %>
    </div>
  </div>

  <%# ── MOBILE ── %>
  <div class="sm:hidden">
    <div style="display:flex; align-items:center; justify-content:space-between; padding:0 18px; height:58px;">
      <a href="/" class="nav-brand">Airbnb</a>
      <button class="hbg" onclick="document.getElementById('mobDrawer').classList.toggle('open')" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>

    <div class="mob-drawer" id="mobDrawer">
      <div style="padding:10px 18px 20px;">

        <div style="display:flex; flex-direction:column; gap:2px; margin-bottom:14px;">
          <% if (isLoggedIn) { %>
            <% if (user && user.userType === 'guest') { %>
              <a href="/bookings" class="mob-link <%= path === '/bookings' ? 'active' : '' %>">
                <span style="width:6px;height:6px;border-radius:50%;background:currentColor;opacity:0.4;flex-shrink:0;"></span>Bookings
              </a>
              <a href="/favourites" class="mob-link <%= path === '/favourites' ? 'active' : '' %>">
                <span style="width:6px;height:6px;border-radius:50%;background:currentColor;opacity:0.4;flex-shrink:0;"></span>Favourites
              </a>
            <% } else { %>
              <a href="/host/add-home" class="mob-link <%= path === '/host/add-home' ? 'active' : '' %>">
                <span style="width:6px;height:6px;border-radius:50%;background:currentColor;opacity:0.4;flex-shrink:0;"></span>Add Home
              </a>
              <a href="/host/list-home" class="mob-link <%= path === '/host/list-home' ? 'active' : '' %>">
                <span style="width:6px;height:6px;border-radius:50%;background:currentColor;opacity:0.4;flex-shrink:0;"></span>My Homes
              </a>
              <a href="/host/orders" class="mob-link <%= path === '/host/orders' || path === '/host/order' ? 'active' : '' %>">
                <span style="width:6px;height:6px;border-radius:50%;background:currentColor;opacity:0.4;flex-shrink:0;"></span>Orders
              </a>
            <% } %>
          <% } %>
        </div>

        <div style="border-top:1px solid #e5e7eb; padding-top:14px; display:flex; align-items:center; justify-content:space-between;">
          <% if (isLoggedIn && user) { %>
            <div style="display:flex; align-items:center; gap:10px;">
              <div style="width:36px;height:36px;border-radius:50%;background:#2563EB;color:#fff;font-size:13px;font-weight:700;display:flex;align-items:center;justify-content:center;">
                <%= user.firstName.charAt(0).toUpperCase() %>
              </div>
              <div>
                <p style="font-size:10px;font-weight:700;color:#2563EB;text-transform:uppercase;letter-spacing:0.5px;"><%= user.userType %></p>
                <p style="font-size:14px;font-weight:600;color:#111827;"><%= user.firstName %></p>
              </div>
            </div>
            <form action="/logout" method="POST" class="inline m-0">
              <button type="submit" class="btn-logout" style="font-size:12px; padding:6px 14px;">Logout</button>
            </form>
          <% } else { %>
            <a href="/login" class="nav-link">Login</a>
            <a href="/signup" class="btn-signup">Sign Up</a>
          <% } %>
        </div>

      </div>
    </div>
  </div>

</nav>