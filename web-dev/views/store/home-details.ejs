<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>User Dashboard</title>
  <link rel="stylesheet" href="/output.css" />
</head>

<body class="min-h-screen flex flex-col bg-gradient-to-br from-blue-100 via-white to-blue-200 text-gray-800">

 <%- include('../partials/navbar') %>

  <main class="min-h-screen flex items-center justify-center bg-gray-100 px-4 py-10">

  <div class="bg-white p-8 md:p-10 rounded-2xl shadow-xl w-full max-w-2xl">

    <h1 class="text-3xl font-bold text-center text-blue-600 mb-6">
    <%= home.houseName %>
    </h1>

    <div class="flex flex-col md:flex-row gap-8">
    
      <!-- Image -->
      <div class="flex justify-center">
        <img src="<%= home.photo %>" alt="Home Image"
             class="w-64 h-64 object-cover rounded-xl shadow-md" />
      </div>

      <!-- Details -->
      <div class="text-gray-700 space-y-4 text-lg">
        <p><strong>📍 Location:</strong> <%= home.location %></p>
        <p><strong>💰 Price:</strong> ₹<%= home.price %></p>
        <p><strong>⭐ Rating:</strong> <%= home.rating %></p>

        <!-- <a href="/book/<%= home._id %>"
        class="inline-block mt-6 w-full py-3 bg-blue-500 text-white text-center rounded-lg shadow hover:bg-blue-600 transition">
        Add to favourites
        </a> -->
        
        <%- include('../partials/favourite') %>
        <!-- <a href="/user"
           class="inline-block mt-3 w-full py-3 bg-gray-200 text-gray-700 text-center rounded-lg hover:bg-gray-300 transition">
          ← Back to Homes
        </a> -->
      </div>

    </div>

  </div>
</main>


  <%- include('../partials/footer') %>
</body>
</html>
