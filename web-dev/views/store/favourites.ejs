<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>User Dashboard</title>
  <link rel="stylesheet" href="/output.css" />
</head>

<body class="min-h-screen flex flex-col bg-gradient-to-br from-blue-100 via-white to-blue-200 text-gray-800">

<%- include('../partials/navbar') %>

  <!-- 🧱 Main Content -->
  <main class="flex-grow flex items-center justify-center px-4 py-10">

    <div class="bg-white p-8 md:p-10 rounded-2xl shadow-xl w-full max-w-3xl">
      <h1 class="text-4xl font-bold text-center text-blue-600 mb-6">
        Welcome to Airbnb User
      </h1>

     

      <div class="space-y-6">
        <% if (registeredHomes.length > 0) { %>
          <% registeredHomes.forEach(home => { %>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 items-center bg-blue-50 hover:bg-blue-100 rounded-xl shadow-sm p-5 transition">

              <!-- Left: Details -->
              <div class="sm:col-span-2">
                <h3 class="text-xl font-semibold text-blue-700 mb-2 flex items-center gap-2">
                  🏠 <%= home.houseName %>
                </h3>

                <ul class="text-gray-700 text-base space-y-1 ml-7">
                  <li><span class="font-medium">📍 Location:</span> <%= home.location %></li>
                  <li><span class="font-medium">💰 Price:</span> ₹<%= home.price %></li>
                  <li><span class="font-medium">⭐ Rating:</span> <%= home.rating %></li>
                </ul>

                <!-- <a href="/book/<%= home._id %>"
                   class="mt-4 inline-block w-48 py-2 bg-blue-500 text-white text-sm font-medium rounded-lg shadow hover:bg-blue-600 transition ml-7 text-center">
                   Add to favourites
                </a> -->
            
              </div>

              <!-- Right: Image -->
              <div class="flex justify-center sm:justify-end">
                <img src="<%= home.photo %>" alt="Home Image"
                     class="w-32 h-32 object-cover rounded-xl shadow-md border border-blue-100 hover:scale-105 transition-transform duration-300" />
              </div>
              <div class="flex justify-center sm:justify-end space-x-2">
  <!-- Remove from Favourites Button -->
  <form action="/favourites/delete/<%= home._id %>" method="POST">
    <button type="submit"
      class="px-3 py-1 bg-red-500 text-white text-sm font-medium rounded-lg shadow hover:bg-red-600 transition">
      Remove
    </button>
  </form>
</div>


            </div>
          <% }) %>
        <% } else { %>
          <p class="text-gray-500 italic text-center py-6">
            No Favourites yet.
          </p>
        <% } %>
      </div>

    </div>
  </main>

<%- include('../partials/footer') %>

</body>
</html>
